generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pais {
  id            String  @id @db.VarChar(2)
  nome          String
  codigoISO3    String  @db.VarChar(3)
  codigoONU     Int
  codigoDDI     String
  codigoMoeda   String  @db.VarChar(3)
  defaultLocale String
  ativo         Boolean @default(true)

  estados Estado[]
}

model Estado {
  id      String  @id @db.VarChar(6)
  paisId  String  @db.VarChar(2)
  nome    String
  sigla   String
  tipo    String
  ativo   Boolean @default(true)

  pais     Pais      @relation(fields: [paisId], references: [id])
  cidades  Cidade[]
}

model Cidade {
  id            String  @id
  estadoId      String
  nome          String
  codigoPostal  String
  latitude      Decimal @db.Decimal(9,6)
  longitude     Decimal @db.Decimal(9,6)
  ativo         Boolean @default(true)

  estado Estado @relation(fields: [estadoId], references: [id])
}